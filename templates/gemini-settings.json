{
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "name": "shipflow-guard",
            "type": "command",
            "command": "shipflow-gemini-guard",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "run_shell_command|shell",
        "hooks": [
          {
            "name": "shipflow-shell-guard",
            "type": "command",
            "command": "shipflow-gemini-guard",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
