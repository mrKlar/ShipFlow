# ShipFlow — Codex CLI execution policy rules
# Prevents destructive operations during implementation.
# Place in .codex/rules/ in your project.

# Block rm -rf on protected directories
prefix_rule(
    pattern=["rm", "-rf", "vp"],
    decision="forbidden",
    justification="ShipFlow: cannot delete verification pack"
)

prefix_rule(
    pattern=["rm", "-rf", ".gen"],
    decision="forbidden",
    justification="ShipFlow: cannot delete generated tests"
)

prefix_rule(
    pattern=["rm", "-rf", "evidence"],
    decision="forbidden",
    justification="ShipFlow: cannot delete evidence"
)

# Require approval for git operations
prefix_rule(
    pattern=["git", ["push", "reset", "rebase"]],
    decision="prompt",
    justification="ShipFlow: require approval for git operations"
)

# Block common draft-time introspection of the installed ShipFlow package.
# During drafting, the agent should use `shipflow draft`, `shipflow lint`,
# and `shipflow gen` rather than reverse-engineering examples/templates/schema files.
prefix_rule(
    pattern=["cat", ["~/.local/bin/shipflow", "/home/n/.local/bin/shipflow"]],
    decision="forbidden",
    justification="ShipFlow: use `shipflow draft --json` instead of inspecting the installed CLI wrapper"
)

prefix_rule(
    pattern=["head", ["~/.local/bin/shipflow", "/home/n/.local/bin/shipflow"]],
    decision="forbidden",
    justification="ShipFlow: use `shipflow draft --json` instead of inspecting the installed CLI wrapper"
)

prefix_rule(
    pattern=["sed", ["~/.local/bin/shipflow", "/home/n/.local/bin/shipflow"]],
    decision="forbidden",
    justification="ShipFlow: do not inspect the installed ShipFlow wrapper during draft"
)

prefix_rule(
    pattern=["realpath", ["~/.local/bin/shipflow", "/home/n/.local/bin/shipflow"]],
    decision="forbidden",
    justification="ShipFlow: do not resolve the installed ShipFlow path during draft"
)

prefix_rule(
    pattern=["readlink", ["~/.local/bin/shipflow", "/home/n/.local/bin/shipflow"]],
    decision="forbidden",
    justification="ShipFlow: do not resolve the installed ShipFlow path during draft"
)

prefix_rule(
    pattern=["ls", ["~/.shipflow", "/home/n/.shipflow", "~/.shipflow/", "/home/n/.shipflow/"]],
    decision="forbidden",
    justification="ShipFlow: do not inspect the installed ShipFlow package during draft"
)

prefix_rule(
    pattern=["find", ["~/.shipflow", "/home/n/.shipflow", "~/.shipflow/", "/home/n/.shipflow/"]],
    decision="forbidden",
    justification="ShipFlow: do not inspect the installed ShipFlow package during draft"
)

prefix_rule(
    pattern=["rg", ["~/.shipflow", "/home/n/.shipflow", "~/.claude/plugins", "/home/n/.claude/plugins"]],
    decision="forbidden",
    justification="ShipFlow: do not mine installed ShipFlow package/plugin contents during draft"
)

prefix_rule(
    pattern=["grep", ["~/.shipflow", "/home/n/.shipflow", "~/.claude/plugins", "/home/n/.claude/plugins"]],
    decision="forbidden",
    justification="ShipFlow: do not mine installed ShipFlow package/plugin contents during draft"
)

prefix_rule(
    pattern=["find", ["~/.claude/plugins", "/home/n/.claude/plugins", "~/.local/share", "/home/n/.local/share", "~/.local/lib", "/home/n/.local/lib", "~/.npm", "/home/n/.npm"]],
    decision="forbidden",
    justification="ShipFlow: do not mine installed plugin/package locations during draft"
)

prefix_rule(
    pattern=["ls", ["~/.claude/plugins", "/home/n/.claude/plugins", "~/.claude/plugins/cache", "/home/n/.claude/plugins/cache"]],
    decision="forbidden",
    justification="ShipFlow: do not inspect installed Claude plugin caches during draft"
)
